{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmitOnError": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "composite": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@ffp/shared-types": ["packages/shared-types/src/index.ts"],
      "@ffp/protocol-core": ["packages/protocol-core/src/index.ts"],
      "@ffp/consensus": ["packages/consensus/src/index.ts"],
      "@ffp/bridges": ["packages/bridges/src/index.ts"],
      "@ffp/tokenomics": ["packages/tokenomics/src/index.ts"],
      "@ffp/agent-node": ["packages/agent-node/src/index.ts"],
      "@ffp/sdk": ["packages/sdk/src/index.ts"],
      "@ffp/dev-tools": ["packages/dev-tools/src/index.ts"]
    }
  }
}
