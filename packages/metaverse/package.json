{
    "name":  "@furge/metaverse",
    "version":  "1.0.0",
    "type":  "module",
    "main":  "./dist/index.js",
    "types":  "./dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "default":  "./dist/index.js"
                          }
                },
    "scripts":  {
                    "build":  "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
                    "dev":  "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --watch",
                    "lint":  "node ../../node_modules/eslint/bin/eslint.js src --ext .ts,.tsx",
                    "typecheck":  "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit"
                },
    "dependencies":  {
                         "@furge/shared-types":  "workspace:*"
                     }
}
