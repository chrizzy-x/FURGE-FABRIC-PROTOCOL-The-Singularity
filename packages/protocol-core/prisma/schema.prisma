generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model RuntimeState {
  id        String   @id
  startedAt DateTime
  updatedAt DateTime @updatedAt
}

model NodeIdentity {
  slot         Int      @id
  agentId      String   @unique
  label        String
  modelFamily  String
  capabilities Json
  publicKey    String
  privateKey   String
  createdAt    DateTime
}

model AgentRecord {
  id            String             @id
  label         String
  modelFamily   String
  publicKey     String
  capabilities  Json
  reputation    Float              @default(100)
  createdAt     DateTime
  proposals     Proposal[]         @relation("proposal_proposer")
  votes         Vote[]             @relation("vote_voter")
  reputationLog ReputationEvent[]
  feesPaid      ProtocolFeeEvent[] @relation("fee_payer")
  feesReceived  ProtocolFeeEvent[] @relation("fee_payee")
}

model Proposal {
  id         String      @id
  proposerId String
  subject    String
  summary    String
  payload    Json
  tags       Json
  createdAt  DateTime
  expiresAt  DateTime
  status     String
  proposer   AgentRecord @relation("proposal_proposer", fields: [proposerId], references: [id])
  votes      Vote[]
  block      Block?
}

model Vote {
  id         String      @id
  proposalId String
  voterId    String
  decision   String
  confidence Float
  reason     String
  createdAt  DateTime
  proposal   Proposal    @relation(fields: [proposalId], references: [id])
  voter      AgentRecord @relation("vote_voter", fields: [voterId], references: [id])

  @@unique([proposalId, voterId])
}

model Block {
  id           String   @id
  height       Int      @unique
  previousHash String
  hash         String
  createdAt    DateTime
  proposalId   String   @unique
  payload      Json
  proposal     Proposal @relation(fields: [proposalId], references: [id])
}

model ReputationEvent {
  id         String      @id
  agentId    String
  proposalId String
  delta      Float
  before     Float
  after      Float
  reason     String
  createdAt  DateTime
  agent      AgentRecord @relation(fields: [agentId], references: [id])
}

model AuditEvent {
  id          String   @id
  type        String
  actorId     String
  referenceId String
  createdAt   DateTime
  payload     Json
}

model BridgeRun {
  id              String   @id
  adapterId       String
  requestId       String   @unique
  status          String
  validation      Json
  response        Json
  recovery        Json?
  consensusStatus String
  createdAt       DateTime
}

model ProtocolFeeEvent {
  id          String      @id
  tokenSymbol String
  amount      Float
  kind        String
  payerId     String
  payeeId     String?
  referenceId String
  createdAt   DateTime
  payer       AgentRecord @relation("fee_payer", fields: [payerId], references: [id])
  payee       AgentRecord? @relation("fee_payee", fields: [payeeId], references: [id])
}

model ProtocolTokenState {
  id                 String   @id
  tokenSymbol        String
  maxSupply          Float
  mintedSupply       Float
  circulatingSupply  Float
  currentReward      Float
  halvingInterval    Int
  nextHalvingAtBlock Int
  updatedAt          DateTime @updatedAt
}

model ProtocolTokenAccount {
  id        String   @id
  ownerId   String
  ownerType String
  balance   Float
  nonce     Int
  createdAt DateTime
  updatedAt DateTime

  @@index([ownerId])
}

model ProtocolTokenEvent {
  id            String   @id
  kind          String
  tokenSymbol   String
  referenceId   String
  blockHeight   Int?
  fromAccountId String?
  toAccountId   String?
  initiatorId   String
  amount        Float
  feeAmount     Float
  nonce         Int?
  supplyAfter   Float
  createdAt     DateTime
  metadata      Json

  @@index([referenceId])
  @@index([createdAt, id])
}
