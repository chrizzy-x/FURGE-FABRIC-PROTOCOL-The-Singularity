{
  "name": "@ffp/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ../../node_modules/typescript/lib/tsc.js -b tsconfig.json",
    "dev": "node ../../node_modules/tsx/dist/cli.mjs watch src/server.ts",
    "lint": "node ../../node_modules/eslint/bin/eslint.js src test --ext .ts --no-error-on-unmatched-pattern",
    "typecheck": "node ../../node_modules/typescript/lib/tsc.js -b tsconfig.json",
    "test": "node ../../node_modules/vitest/vitest.mjs run --config ../../vitest.config.ts test"
  },
  "dependencies": {
    "@fastify/cors": "latest",
    "@ffp/dev-tools": "workspace:*",
    "@ffp/sdk": "workspace:*",
    "@ffp/shared-types": "workspace:*",
    "fastify": "latest"
  }
}
